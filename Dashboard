                                btn.classList.replace('hover:bg-emerald-700', 'hover:bg-orange-600');
                            }, 3000);
                        } else {
                            throw new Error(&quot;Parsed file doesn't match expected CSV format.&quot;);
                        }
                    },
                    error: function(err) {
                        console.warn(&quot;Error parsing the CSV data: &quot; + err.message);
