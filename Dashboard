                            btn.innerHTML = '&lt;i class=&quot;fa-solid fa-check&quot;&gt;&lt;/i&gt; Data Synced';
                            btn.classList.replace('bg-accent', 'bg-emerald-600');
                            btn.classList.replace('hover:bg-orange-600', 'hover:bg-emerald-700');
                            setTimeout(() =&gt; { 
                                btn.innerHTML = originalHTML; 
