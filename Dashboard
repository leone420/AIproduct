        /** ==========================================
         * MAP RENDERING LOGIC
         * ========================================== */
        async function fetchGeoJSON() {
            try {
                if (LOCAL_NEPAL_GEOJSON) {
                    nepalGeoJSON = LOCAL_NEPAL_GEOJSON;
                    return;
                }

                let fetchedData = null;
                
                try {
                    const geoText = await fetchRobust(EXTERNAL_ASSETS.geoJsonMap);
                    fetchedData = JSON.parse(geoText);
                    console.log(&quot;Successfully auto-loaded Map data from Google Drive.&quot;);
                } catch(e) {
                    console.warn(&quot;Google Drive GeoJSON fetch failed, falling back to external sources.&quot;, e);
                }
                
                if (!fetchedData) {
                    const urlsToTry = [
                        'https://cdn.jsdelivr.net/gh/mesaugat/geoJSON-Nepal@master/nepal-provinces.geojson',
                        'https://raw.githubusercontent.com/mesaugat/geoJSON-Nepal/master/nepal-provinces.geojson'
                    ];

                    for (let url of urlsToTry) {
                        if (fetchedData) break;
                        try {
                            const geoText = await fetchRobust(url);
                            fetchedData = JSON.parse(geoText);
                        } catch(e) {
                            console.warn(&quot;Map fallback fetch blocked for:&quot;, url);
                        }
                    }
                }

                if (!fetchedData) {
                    try {
                        const apiRes = await fetch('https://www.geoboundaries.org/api/current/gbOpen/NPL/ADM1/');
                        const metaData = await apiRes.json();
                        const geoRes = await fetch(metaData.gjDownloadURL);
                        fetchedData = await geoRes.json();
                    } catch(e) { console.warn(&quot;GeoBoundaries fallback failed.&quot;); }
                }

                if (fetchedData) {
                    nepalGeoJSON = fetchedData;
                } else {
                    mapFetchFailed = true;
                    showMapError();
                }
            } catch (err) {
                console.error(&quot;Final map error:&quot;, err);
                mapFetchFailed = true;
                showMapError();
            }
        }

