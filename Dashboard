                    let maxV = Math.max(...allVals);
                    let diff = maxV - minV;
                    let pad = diff &lt; 5 ? 2 : (diff * 0.15); 
                    
                    yAxisConfig.min = Math.max(0, Math.floor(minV - pad));
                    let computedMax = Math.ceil(maxV + pad);
                    yAxisConfig.max = maxV &lt;= 100 ? Math.min(100, computedMax) : computedMax;
