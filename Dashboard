            if (year === '2019') {
                btn2019.className = &quot;px-3 py-1 text-xs font-medium rounded-md bg-white shadow-sm text-primary transition-all&quot;;
                btn2024.className = &quot;px-3 py-1 text-xs font-medium rounded-md text-slate-500 hover:text-slate-700 transition-all&quot;;
            } else {
