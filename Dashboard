            const ctx = document.getElementById(canvasId);
            if (!ctx) return;

            let subset = indicatorData.filter(d =&gt; d.Disagg_Type === disaggType);
            let rawCategories = getUnique(subset, 'Disagg_Category');
            let categories = sortOrder ? sortOrder.filter(c =&gt; rawCategories.includes(c)) : rawCategories;

            if (chartInstances[canvasId]) {
                chartInstances[canvasId].destroy();
            }

            if (subset.length === 0) {
                chartInstances[canvasId] = new Chart(ctx, { type: 'bar', data: { labels: ['No Data Available'], datasets: [] }, options: { responsive: true, maintainAspectRatio: false } });
                return;
            }

            let chartData, chartOptions, chartConfigType;
            let yAxisConfig = { ticks: { callback: function(value) { return value + '%' } } };

            if (currentChartType === 'bar') {
                chartConfigType = 'bar';
                
                let data2019 = categories.map(cat =&gt; { let match = subset.find(d =&gt; d.Disagg_Category === cat &amp;&amp; d.Survey_Year === '2019'); return match &amp;&amp; match.Value !== &quot;N/A&quot; ? parseFloat(match.Value) : null; });
