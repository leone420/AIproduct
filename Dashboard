        function getProvinceNameFromFeature(feature) {
            const props = feature.properties;
            const rawName = String(props.ADM1_EN || props.shapeName || props.PROVINCE || props.Province || props.name || props.PR_NAME || '').toLowerCase();
            
            if (rawName.includes('1') || rawName.includes('koshi')) return 'Koshi';
            if (rawName.includes('2') || rawName.includes('madhesh') || rawName.includes('madesh') || rawName.includes('pradesh 2')) return 'Madhesh';
            if (rawName.includes('3') || rawName.includes('bagmati')) return 'Bagmati';
            if (rawName.includes('4') || rawName.includes('gandaki')) return 'Gandaki';
            if (rawName.includes('5') || rawName.includes('lumbini')) return 'Lumbini';
            if (rawName.includes('6') || rawName.includes('karnali')) return 'Karnali';
            if (rawName.includes('7') || rawName.includes('sudur') || rawName.includes('sudurpashchim')) return 'Sudurpashchim';
            return 'Unknown';
        }

        function getColor(d) {
            if (d === null || d === 'No Data') return '#e2e8f0'; 
            return d &gt;= currentMapBreaks[3] ? '#082f49' : 
                   d &gt;= currentMapBreaks[2] ? '#0284c7' :
                   d &gt;= currentMapBreaks[1] ? '#38bdf8' :
                   d &gt;= currentMapBreaks[0] ? '#bae6fd' : '#f0f9ff'; 
        }

        function updateMapLegend(minVal, maxVal) {
            const legendContainer = document.getElementById('mapLegendContent');
            if (!legendContainer) return;

            const diff = maxVal - minVal;
            const precision = diff &lt; 5 ? 2 : 1; 
            const format = (v) =&gt; v.toFixed(precision);

            legendContainer.innerHTML = `
                &lt;div class=&quot;font-bold mb-1.5 text-slate-700 uppercase tracking-wider border-b border-slate-100 pb-1&quot;&gt;Value (%)&lt;/div&gt;
                &lt;div class=&quot;flex items-center gap-2 mb-1&quot;&gt;&lt;span class=&quot;w-3 h-3 inline-block bg-[#082f49] rounded-sm border border-slate-400&quot;&gt;&lt;/span&gt; ${format(currentMapBreaks[3])} - ${format(maxVal)}%&lt;/div&gt;
                &lt;div class=&quot;flex items-center gap-2 mb-1&quot;&gt;&lt;span class=&quot;w-3 h-3 inline-block bg-[#0284c7] rounded-sm border border-slate-400&quot;&gt;&lt;/span&gt; ${format(currentMapBreaks[2])} - ${format(currentMapBreaks[3])}%&lt;/div&gt;
                &lt;div class=&quot;flex items-center gap-2 mb-1&quot;&gt;&lt;span class=&quot;w-3 h-3 inline-block bg-[#38bdf8] rounded-sm border border-slate-400&quot;&gt;&lt;/span&gt; ${format(currentMapBreaks[1])} - ${format(currentMapBreaks[2])}%&lt;/div&gt;
                &lt;div class=&quot;flex items-center gap-2 mb-1&quot;&gt;&lt;span class=&quot;w-3 h-3 inline-block bg-[#bae6fd] rounded-sm border border-slate-400&quot;&gt;&lt;/span&gt; ${format(currentMapBreaks[0])} - ${format(currentMapBreaks[1])}%&lt;/div&gt;
                &lt;div class=&quot;flex items-center gap-2&quot;&gt;&lt;span class=&quot;w-3 h-3 inline-block bg-[#f0f9ff] rounded-sm border border-slate-400&quot;&gt;&lt;/span&gt; ${format(minVal)} - ${format(currentMapBreaks[0])}%&lt;/div&gt;
            `;
        }

        function renderMap(data) {
            currentProvinceData = data.filter(d =&gt; d.Disagg_Type === 'Province');
            
            if (!mapInstance) {
                mapInstance = L.map('nepalMap', {
                    zoomControl: false,
                    attributionControl: false,
                    scrollWheelZoom: false,
                    dragging: !L.Browser.mobile
                }).setView([28.3949, 84.1240], 6);
                
                L.control.zoom({ position: 'topleft' }).addTo(mapInstance);
            }

            if (nepalGeoJSON) {
                updateMapLayer();
            } else if (mapFetchFailed) {
                showMapError();
            } else {
                let retries = 0;
                const checkInterval = setInterval(() =&gt; {
                    if (nepalGeoJSON) {
                        clearInterval(checkInterval);
                        updateMapLayer();
                    } else if (mapFetchFailed || retries &gt; 10) {
                        clearInterval(checkInterval);
                        showMapError();
                    }
                    retries++;
                }, 500);
            }
        }

        function updateMapLayer() {
            if (!nepalGeoJSON || !mapInstance) return;
            
            const loading = document.getElementById('mapLoading');
            if(loading) loading.style.display = 'none';

            let vals = currentProvinceData
                .filter(d =&gt; d.Survey_Year === currentMapYear &amp;&amp; d.Value !== &quot;N/A&quot; &amp;&amp; d.Value !== null)
                .map(d =&gt; parseFloat(d.Value));

            let minVal = 0, maxVal = 100;
            
            if (vals.length &gt; 0) {
                minVal = Math.min(...vals);
                maxVal = Math.max(...vals);

                if (minVal === maxVal) {
                    if (minVal === 0) { maxVal = 1; } else { minVal = minVal * 0.9; maxVal = maxVal * 1.1; }
                }

                let step = (maxVal - minVal) / 5;
                currentMapBreaks = [
                    minVal + step,
                    minVal + step * 2,
                    minVal + step * 3,
                    minVal + step * 4
                ];
            } else {
                currentMapBreaks = [20, 40, 60, 80]; 
            }
            
            updateMapLegend(minVal, maxVal);

            if (geojsonLayer) {
                mapInstance.removeLayer(geojsonLayer);
            }

            geojsonLayer = L.geoJSON(nepalGeoJSON, {
                style: function(feature) {
                    const provName = getProvinceNameFromFeature(feature);
                    const record = currentProvinceData.find(d =&gt; d.Disagg_Category === provName &amp;&amp; d.Survey_Year === currentMapYear);
                    const val = record &amp;&amp; record.Value !== &quot;N/A&quot; ? parseFloat(record.Value) : null;
                    
                    return {
                        fillColor: getColor(val),
                        weight: 1.5,
                        opacity: 1,
                        color: '#cbd5e1',
                        fillOpacity: val !== null ? 0.9 : 0.2
                    };
                },
                onEachFeature: function(feature, layer) {
                    const provName = getProvinceNameFromFeature(feature);
                    const record = currentProvinceData.find(d =&gt; d.Disagg_Category === provName &amp;&amp; d.Survey_Year === currentMapYear);
                    const val = record &amp;&amp; record.Value !== &quot;N/A&quot; ? parseFloat(record.Value) : 'No Data';
                    
                    const tooltipContent = `
                        &lt;div class=&quot;text-center font-sans&quot;&gt;
                            &lt;strong class=&quot;block text-[13px] border-b border-slate-600 pb-1 mb-1&quot;&gt;${provName}&lt;/strong&gt;
                            &lt;span class=&quot;text-[15px] font-bold text-[#38bdf8]&quot;&gt;${val}${val !== 'No Data' ? '%' : ''}&lt;/span&gt;
                        &lt;/div&gt;
                    `;
                    
                    layer.bindTooltip(tooltipContent, {
                        sticky: true,
                        className: 'bg-slate-800 text-white border-none rounded-md px-3 py-2 shadow-lg',
                        direction: 'top'
                    });
                    
                    layer.on({
                        mouseover: (e) =&gt; {
                            const l = e.target;
                            l.setStyle({ weight: 3, color: '#f59e0b', fillOpacity: 1 }); 
                            if (!L.Browser.ie &amp;&amp; !L.Browser.opera &amp;&amp; !L.Browser.edge) {
                                l.bringToFront();
                            }
                        },
                        mouseout: (e) =&gt; geojsonLayer.resetStyle(e.target)
                    });
                }
            }).addTo(mapInstance);

            if (geojsonLayer) {
                const bounds = geojsonLayer.getBounds();
                if (bounds.isValid()) {
                    const mapContainer = document.getElementById('provinceMapContainer');
                    if (mapContainer &amp;&amp; !mapContainer.classList.contains('hidden') &amp;&amp; mapContainer.offsetWidth &gt; 0) {
                        mapInstance.fitBounds(bounds, { padding: [10, 10] });
                    }
                }
            }
        }

        /** ==========================================
         * EXPORT LOGIC
         * ========================================== */
        async function exportChart(canvasId, format, disaggType) {
            const currentIndicator = document.getElementById('indicatorFilter').value;
            const safeTitle = currentIndicator.replace(/[^a-z0-9]/gi, '_').substring(0, 50);
            const fileName = `SDG_${disaggType}_${safeTitle}`;

            if (format === 'csv') {
                let data = mySDGData.filter(d =&gt; d.Sub_Indicator === currentIndicator &amp;&amp; d.Disagg_Type === disaggType);
                
                if (canvasId === 'chartNationalTrend') {
                    const compVal = document.getElementById('compareIndicatorFilter').value;
                    if (compVal) {
                        const compData = mySDGData.filter(d =&gt; d.Sub_Indicator === compVal &amp;&amp; d.Disagg_Type === 'Total');
                        data = data.concat(compData);
                    }
                }
                
                if (data.length === 0) {
                    alert('No data available to export.');
                    return;
                }

                const headers = Object.keys(data[0]).join(',');
                const rows = data.map(obj =&gt; 
                    Object.values(obj).map(val =&gt; `&quot;${String(val).replace(/&quot;/g, '&quot;&quot;')}&quot;`).join(',')
                ).join('\n');
                
                const csvContent = headers + '\n' + rows;
                const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
                const url = URL.createObjectURL(blob);
                triggerDownload(url, fileName + &quot;.csv&quot;);
                URL.revokeObjectURL(url);

            } else if (format === 'png') {
                if (canvasId === 'chartProvince' &amp;&amp; currentChartType === 'bar') {
                    if (typeof html2canvas !== 'undefined') {
                        const mapEl = document.getElementById('provinceMapContainer');
                        html2canvas(mapEl, { useCORS: true, backgroundColor: '#f8fafc' }).then(canvas =&gt; {
                            triggerDownload(canvas.toDataURL(&quot;image/png&quot;), fileName + &quot;_Map.png&quot;);
                        });
                    } else {
                        alert(&quot;Map export requires html2canvas library.&quot;);
                    }
                } else {
                    const canvas = document.getElementById(canvasId);
                    if (canvas) {
                        triggerDownload(canvas.toDataURL(&quot;image/png&quot;), fileName + &quot;.png&quot;);
                    }
                }
            }
        }

        function triggerDownload(dataUrl, filename) {
            const link = document.createElement('a');
            link.download = filename;
            link.href = dataUrl;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        /** ==========================================
         * ONBOARDING TOUR LOGIC (Intro.js)
         * ========================================== */
        function startTour() {
            let steps = [
                {
                    element: document.getElementById('tour-sidebar'),
                    title: '1. Select an SDG Goal',
                    intro: 'Click on any Sustainable Development Goal to filter the indicators relevant to that specific chapter.'
                },
                {
                    element: document.getElementById('tour-indicator-select'),
                    title: '2. Choose an Indicator',
                    intro: 'Select a specific survey indicator from the dropdown to visualize its data across various demographics.'
                },
                {
                    element: document.getElementById('tour-view-toggle'),
                    title: '3. Visualization Mode',
                    intro: 'Switch between &quot;Comparison&quot; mode (side-by-side bar charts and map) and &quot;Trend View&quot; (slopegraphs highlighting changes over time).'
                },
                {
                    element: document.getElementById('tour-kpi-cards'),
                    title: '4. National Summary',
                    intro: 'Instantly view the high-level national totals for both survey rounds, along with the calculated net percentage point change.'
                }
            ];

            if (currentChartType === 'line') {
                steps.push({
                    element: document.getElementById('tour-compare'),
                    title: '5. Compare Trends',
                    intro: 'In Trend View, select any other indicator here to see how its national trend compares directly against your primary selection.'
                });
            } else {
                steps.push({
                    element: document.getElementById('mapYearToggle'),
                    title: '5. Interactive Map',
                    intro: 'In Comparison mode, toggle between survey years to see the geographic distribution of the indicator across the provinces.'
                });
            }

            steps.push({
                element: document.getElementById('tour-export'),
                title: '6. Export Data &amp; Images',
                intro: 'Every chart has an export menu. Download the exact data behind the chart as a CSV, or save a crisp PNG image for your reports and presentations.'
            });

            introJs().setOptions({
                steps: steps,
                showProgress: true,
                showBullets: false,
                tooltipClass: 'customTooltip',
                nextLabel: 'Next &lt;i class=&quot;fa-solid fa-chevron-right ml-1 text-xs&quot;&gt;&lt;/i&gt;',
                prevLabel: '&lt;i class=&quot;fa-solid fa-chevron-left mr-1 text-xs&quot;&gt;&lt;/i&gt; Back',
                doneLabel: '&lt;i class=&quot;fa-solid fa-check mr-1 text-xs&quot;&gt;&lt;/i&gt; Got it!'
            }).start();
        }
